#!/usr/bin/make -f

export DEB_BUILD_MAINT_OPTIONS = hardening=+all

%:
	dh $@

override_dh_auto_configure:
	dh_auto_configure -- \
		-DCMAKE_BUILD_TYPE=Release \
		-DAPP_VERSION_MAJOR:STRING=$(shell awk -F= '/^VER_MAJOR/{ print $$2 }' Makefile) \
		-DAPP_VERSION_MINOR:STRING=$(shell awk -F= '/^VER_MINOR/{ print $$2 }' Makefile) \
		-DAPP_VERSION_RELEASE:STRING=$(shell awk -F= '/^VER_RELEASE/{ print $$2 }' Makefile)
